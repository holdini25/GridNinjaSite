{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10.9 <11"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run seo:validate",
    "build": "next build",
    "postbuild": "node scripts/validate-contact-build.mjs",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run --coverage",
    "test:unit:dispatch-envelope": "vitest run tests/unit/dispatch-envelope",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:required": "node scripts/run-required-integration-tests.mjs",
    "test:e2e": "playwright test",
    "test:e2e:dispatch-envelope": "playwright test tests/e2e/dispatch-envelope.spec.ts",
    "test:e2e:lead-forms": "playwright test tests/e2e/lead-forms.spec.ts",
    "test:staging:contact": "playwright test --config=playwright.staging.config.ts",
    "test:seo": "playwright test --config=playwright.seo.config.ts",
    "test:seo:smoke": "playwright test --config=playwright.seo-smoke.config.ts",
    "seo:validate": "node scripts/seo/validate-source-contracts.mjs && node scripts/seo/validate-evidence-releases.mjs && vitest run tests/unit/seo --coverage.enabled=false",
    "lighthouse": "npm run lighthouse:collect && npm run lighthouse:validate-budgets",
    "lighthouse:collect": "lhci autorun --config=./lighthouserc.cjs",
    "lighthouse:validate-budgets": "node scripts/seo/validate-lighthouse-budgets.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:check": "drizzle-kit check",
    "contact:qstash:configure": "node scripts/configure-contact-qstash.mjs",
    "brand:generate": "node scripts/generate-brand-derivatives.mjs",
    "brand:check": "node scripts/generate-brand-derivatives.mjs --check",
    "validate": "npm run brand:check && npm run lint && npm run typecheck && npm run build",
    "audit:prod": "npm audit --omit=dev --audit-level=high"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@upstash/qstash": "^2.11.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-array": "^3.2.4",
    "d3-interpolate": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "drizzle-orm": "^0.45.2",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "next": "16.2.9",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3-array": "^3.2.2",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "fast-check": "^4.8.0",
    "jsdom": "^29.1.1",
    "pg": "^8.22.0",
    "png-to-ico": "^3.0.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
