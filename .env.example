# Local public URL and exact browser request allowlists.
# In Vercel Production, set NEXT_PUBLIC_SITE_URL=https://www.gridninja.ai.
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
CONTACT_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Neon / Drizzle.
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Cloudflare Turnstile. Use Cloudflare's documented test keys locally.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
TURNSTILE_ALLOWED_HOSTNAMES=127.0.0.1,localhost

# Upstash Redis rate limiting.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash QStash publishing and signed internal route verification.
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Rotate this independently from provider credentials. Never expose it publicly.
LEAD_PSEUDONYM_SECRET=

# Required internal email delivery.
RESEND_API_KEY=
LEAD_EMAIL_FROM=GridNinja <no-reply@gridninja.ai>
LEAD_EMAIL_TO=

# Optional CRM delivery. Configure both values or neither.
LEAD_WEBHOOK_URL=
LEAD_WEBHOOK_SIGNING_SECRET=

# Required in production. Payloads contain operational IDs/status only, never PII.
LEAD_ALERT_WEBHOOK_URL=
LEAD_ALERT_WEBHOOK_TOKEN=
